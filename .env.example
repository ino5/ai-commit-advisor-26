DATABASE_URL=postgresql+psycopg2://ai_user:ai_password@localhost:5432/ai_commit_advisor
PGVECTOR_DIMENSION=1536

# LLM settings
# mock: no external call
# local_openai: OpenAI-compatible local server such as LM Studio
LLM_PROVIDER=mock
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5-coder-7b-instruct
EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1

# Optional: restrict project Git repository paths to this app-server directory.
# Example for an internal Linux server: /srv/ai-commit-advisor/repos
REPO_STORAGE_ROOT=

# Neo4j knowledge graph read model.
# Set NEO4J_ENABLED=false only when you want to run without Neo4j.
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ai_commit_advisor
NEO4J_DATABASE=
