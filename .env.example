DATABASE_URL=postgresql+psycopg2://ai_user:ai_password@localhost:5432/ai_commit_advisor
PGVECTOR_DIMENSION=1536

# LLM settings
# mock: no external call
# local_openai: OpenAI-compatible local server such as LM Studio
LLM_PROVIDER=mock
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5-coder-7b-instruct
EMBEDDING_PROVIDER=mock
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1

# Docker Compose app overrides. Leave these commented to use docker-compose.yml defaults:
# local_openai, host.docker.internal:12345, nomic v1.5, dimension 768.
# Use DOCKER_* rather than the host-only 127.0.0.1 URLs above.
# DOCKER_LLM_PROVIDER=local_openai
# DOCKER_LLM_BASE_URL=http://host.docker.internal:12345/v1
# DOCKER_LLM_MODEL=qwen2.5-coder-7b-instruct
# DOCKER_EMBEDDING_PROVIDER=local_openai
# DOCKER_EMBEDDING_BASE_URL=http://host.docker.internal:12345/v1
# DOCKER_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# DOCKER_PGVECTOR_DIMENSION=768

# Optional: restrict project Git repository paths to this app-server directory.
# Example for an internal Linux server: /srv/ai-commit-advisor/repos
REPO_STORAGE_ROOT=

# Neo4j knowledge graph read model.
# Set NEO4J_ENABLED=false only when you want to run without Neo4j.
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ai_commit_advisor
NEO4J_DATABASE=
NEO4J_WRITE_BATCH_SIZE=500
NEO4J_RETRY_ATTEMPTS=2
NEO4J_RETRY_BACKOFF_SECONDS=0.5
