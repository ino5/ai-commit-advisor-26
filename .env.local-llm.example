DATABASE_URL=postgresql+psycopg2://ai_user:ai_password@localhost:5432/ai_commit_advisor
PGVECTOR_DIMENSION=768

# Local LLM / embedding demo settings.
# Start LM Studio Local Server on port 12345 before running the app.
# Load qwen2.5-coder-7b-instruct with context length 8192.
LLM_PROVIDER=local_openai
LLM_BASE_URL=http://127.0.0.1:12345/v1
LLM_API_KEY=
LLM_MODEL=qwen2.5-coder-7b-instruct

EMBEDDING_PROVIDER=local_openai
EMBEDDING_BASE_URL=http://127.0.0.1:12345/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v2-moe

# Optional: restrict project Git repository paths to this app-server directory.
# Example for an internal Linux server: /srv/ai-commit-advisor/repos
REPO_STORAGE_ROOT=

# Optional managed clone workspace for Git URL project registration.
# Local Python can use the host path directly, so MANAGED_REPO_CONTAINER_PREFIX stays empty.
MANAGED_REPO_STORAGE_ROOT=
MANAGED_REPO_CONTAINER_PREFIX=
MANAGED_GIT_ALLOWED_HOSTS=github.com,gitlab.com,bitbucket.org
GIT_OPERATION_TIMEOUT_SECONDS=300

# Neo4j knowledge graph read model.
# Set NEO4J_ENABLED=false only when you want to run without Neo4j.
NEO4J_ENABLED=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ai_commit_advisor
NEO4J_DATABASE=
NEO4J_WRITE_BATCH_SIZE=500
NEO4J_RETRY_ATTEMPTS=2
NEO4J_RETRY_BACKOFF_SECONDS=0.5
